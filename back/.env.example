# ==========================================================
#  Refleja API — plantilla de configuración.
#  Copia a .env y rellena. En PRODUCCIÓN usa los valores comentados.
# ==========================================================
ENV=production
APP_HOST=127.0.0.1
APP_PORT=20832

# --- Base de datos (MariaDB en producción) ---
DATABASE_URL=mysql+pymysql://refleja:TU_PASSWORD@127.0.0.1:3306/refleja?charset=utf8mb4

# --- CORS ---
CORS_ORIGINS=https://refleja.org,https://www.refleja.org

# --- Secretos de firma: genera con  openssl rand -hex 48 ---
JWT_SECRET=GENERA_UNO
PUBLIC_TOKEN_SECRET=GENERA_OTRO
VID_HMAC_KEY=GENERA_OTRO_MAS

# --- Tiempos de vida ---
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=7
PUBLIC_TOKEN_TTL_DAYS=30

# --- Cloudflare Turnstile (SECRET keys, nunca en el front) ---
TURNSTILE_SECRET_LOGIN=
TURNSTILE_SECRET_INVISIBLE=
DEV_BYPASS_TURNSTILE=false

# --- Cookies del refresh token ---
# refleja.org y api.refleja.org son el MISMO site (mismo dominio registrable),
# así que SameSite=lax funciona y además bloquea CSRF. Cookie host-only en la
# API (COOKIE_DOMAIN vacío). NO uses "none" salvo que el front esté en otro
# dominio distinto de refleja.org.
COOKIE_DOMAIN=
COOKIE_SECURE=true
COOKIE_SAMESITE=lax

# --- Blindaje de origen (opcional; genera con openssl rand -hex 24) ---
# Si lo defines, Cloudflare debe inyectar este header vía Transform Rule.
ORIGIN_SECRET=
ORIGIN_SECRET_HEADER=X-Origin-Secret
